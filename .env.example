# URL of your n8n webhook that handles plant identification.
# The app will POST a multipart form with the field `image` (file).
# It expects a JSON response of the shape:
#   {
#     "species": "Monstera deliciosa",
#     "common_name": "Swiss cheese plant",
#     "confidence": 0.92,
#     "care_notes": "Bright indirect light, water when top 2cm of soil is dry...",
#     "growth": { "height_cm": 45, "leaf_count": 7 }   # optional
#   }
# All fields are optional; missing fields just won't be pre-filled.
N8N_IDENTIFY_WEBHOOK_URL=http://n8n:5678/webhook/plant-identify

# Optional shared secret. If set, the app sends header `X-Plant-Tracker-Token: <value>`.
N8N_WEBHOOK_TOKEN=

# Where SQLite + photos live inside the container. Mount a host volume here.
DATA_DIR=/data

# Max upload size in megabytes
MAX_UPLOAD_MB=25

# Set to 1 to skip n8n entirely (useful for first-run / dev).
DISABLE_IDENTIFY=0
