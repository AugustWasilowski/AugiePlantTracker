# URL of your n8n webhook that handles plant identification.
# The app will POST a multipart form with the field `image` (file).
# It expects a JSON response of the shape:
#   {
#     "species": "Monstera deliciosa",
#     "common_name": "Swiss cheese plant",
#     "confidence": 0.92,
#     "care_notes": "Bright indirect light, water when top 2cm of soil is dry...",
#     "growth": { "height_cm": 45, "leaf_count": 7 }   # optional
#   }
# All fields are optional; missing fields just won't be pre-filled.
N8N_IDENTIFY_WEBHOOK_URL=http://n8n:5678/webhook/plant-identify

# Optional shared secret. If set, the app sends header `X-Plant-Tracker-Token: <value>`.
N8N_WEBHOOK_TOKEN=

# Where SQLite + photos live inside the container. Mount a host volume here.
DATA_DIR=/data

# Max upload size in megabytes
MAX_UPLOAD_MB=25

# Set to 1 to skip n8n entirely (useful for first-run / dev).
DISABLE_IDENTIFY=0

# ---- Immich auto-import (optional) ----
# Leave IMMICH_URL or IMMICH_API_KEY blank to disable the sync loop entirely.
# When configured, a background task polls Immich every SYNC_INTERVAL_MINUTES,
# runs CLIP smart-search, geofences to your home, and drops new candidates
# into the inbox (Photo rows with plant_id=NULL).

# Where Immich is reachable from inside the plant-tracker container.
# If both run on the same Docker host with default networking, the LAN IP works.
IMMICH_URL=
# Account Settings -> API Keys in Immich. Read scope is enough.
IMMICH_API_KEY=

# Decimal degrees of your house. Right-click in Google Maps to grab coords.
# Anything outside HOME_RADIUS_KM is filtered out of auto-import.
HOME_LAT=0.0
HOME_LON=0.0
HOME_RADIUS_KM=0.5

# How often the background worker polls Immich. 0 disables the loop.
SYNC_INTERVAL_MINUTES=15
# CLIP smart-search queries (comma-separated). De-duped by Immich asset id.
CLIP_QUERIES=houseplant,potted plant indoors,indoor plant,succulent plant,cactus in a pot,close-up of a plant leaf,variegated plant leaf,small plant in a pot,terrarium with plants,miniature indoor garden,plant under a grow light,plant cutting propagation,hanging plant indoors,flowering houseplant,philodendron,monstera plant,pothos vine,snake plant,orchid in bloom
CLIP_RESULTS_PER_QUERY=25
